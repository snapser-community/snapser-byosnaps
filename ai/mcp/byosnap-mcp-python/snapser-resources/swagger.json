{
    "paths": {
        "/v1/byosnap-mcp/mcp": {
            "post": {
                "summary": "MCP JSON-RPC endpoint",
                "description": "Snapser-hosted MCP endpoint that speaks JSON-RPC 2.0 and exposes initialize, tools/list, and tools/call.\n",
                "operationId": "McpRpc",
                "parameters": [
                    {
                        "in": "query",
                        "name": "api-key",
                        "schema": {
                            "type": "string"
                        },
                        "required": true,
                        "description": "API key used for authentication"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/MCPRequestSchema"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful JSON-RPC response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessResponseSchema"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "JSON-RPC error or auth failure",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponseSchema"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponseSchema"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "info": {
        "title": "BYOSnap OpenAI Apps SDK Python Example",
        "version": "1.0.0"
    },
    "openapi": "3.0.2",
    "components": {
        "schemas": {
            "MCPRequestSchema": {
                "type": "object",
                "properties": {
                    "id": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "integer"
                            }
                        ],
                        "description": "JSON-RPC request id (string or number)"
                    },
                    "params": {
                        "type": "object",
                        "description": "JSON-RPC params object"
                    },
                    "method": {
                        "type": "string",
                        "description": "JSON-RPC method name"
                    }
                },
                "required": [
                    "method"
                ]
            },
            "SuccessResponseSchema": {
                "type": "object",
                "properties": {
                    "id": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "integer"
                            }
                        ],
                        "description": "Echoed JSON-RPC request id."
                    },
                    "jsonrpc": {
                        "type": "string",
                        "description": "JSON-RPC version, always '2.0'.",
                        "example": "2.0"
                    },
                    "result": {
                        "type": "object",
                        "description": "JSON-RPC result object containing MCP tool/resource output."
                    }
                },
                "required": [
                    "jsonrpc"
                ]
            },
            "ErrorResponseSchema": {
                "type": "object",
                "properties": {
                    "id": {
                        "nullable": true,
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "integer"
                            }
                        ],
                        "description": "Echoed request id; null/omitted for parse errors."
                    },
                    "jsonrpc": {
                        "type": "string",
                        "description": "JSON-RPC version, always '2.0'.",
                        "example": "2.0"
                    },
                    "error": {
                        "type": "object",
                        "description": "JSON-RPC error object (code, message, optional data).",
                        "example": {
                            "code": -32600,
                            "message": "Invalid Request"
                        }
                    }
                },
                "required": [
                    "error",
                    "jsonrpc"
                ]
            }
        }
    }
}