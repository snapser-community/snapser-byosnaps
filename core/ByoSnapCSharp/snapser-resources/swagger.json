            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ErrorResponseSchema": {
        "type": "object",
        "properties": {
          "errorMessage": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ExportSettingsSchema": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "nullable": true
          },
          "exportedAt": {
            "type": "integer",
            "format": "int64"
          },
          "data": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/components/schemas/SettingsSchema"
              }
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GroupComponentItemSchema": {
        "type": "object",
        "properties": {
          "componentOne": {
            "$ref": "#/components/schemas/SettingsComponentSchema"
          },
          "componentTwo": {
            "$ref": "#/components/schemas/SettingsComponentSchema"
          },
          "componentThree": {
            "$ref": "#/components/schemas/SettingsComponentSchema"
          },
          "componentFour": {
            "type": "boolean",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SettingsComponentSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "type": {
            "type": "string",
            "nullable": true
          },
          "value": {
            "nullable": true
          },
          "components": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GroupComponentItemSchema"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SettingsSchema": {
        "type": "object",
        "properties": {
          "sections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SettingsSectionSchema"
