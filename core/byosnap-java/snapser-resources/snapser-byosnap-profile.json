{
    "name": "Byosnap Java Core",
    "description": "A minimal starter scaffold for a Java BYOSnap. Every endpoint Snapser expects is present but stubbed, ready for you to fill in your own logic.",
    "platform": "linux/arm64",
    "language": "java",
    "prefix": "/v1",
    "ingress": {
        "external_port": {
            "name": "http",
            "port": 5003
        },
        "internal_ports": []
    },
    "readiness_probe_config": {
        "initial_delay_seconds": 30,
        "path": "/healthz"
    },
    "dev_template": {
        "cpu": 500,
        "memory": 1.0,
        "min_replicas": 1,
        "cmd": "",
        "args": [],
        "env_params": [
            {
                "key": "SNAPSER_ENVIRONMENT",
                "value": "DEVELOPMENT"
            }
        ]
    },
    "stage_template": {
        "cpu": 500,
        "memory": 1.0,
        "min_replicas": 1,
        "cmd": "",
        "args": [],
        "env_params": [
            {
                "key": "SNAPSER_ENVIRONMENT",
                "value": "STAGING"
            }
        ]
    },
    "prod_template": {
        "cpu": 500,
        "memory": 1.0,
        "min_replicas": 2,
        "cmd": "",
        "args": [],
        "env_params": [
            {
                "key": "SNAPSER_ENVIRONMENT",
                "value": "PRODUCTION"
            }
        ]
    }
}