      "put": {
        "description": "Update the settings from the custom HTML configuration tool.",
        "summary": "Custom Configuration Tool",
        "operationId": "UpdateSettingsCustom",
        "parameters": [
          {
            "type": "string",
            "name": "tool_id",
            "in": "query"
          },
          {
            "type": "string",
            "name": "environment",
            "in": "query"
          },
          {
            "name": "body",
            "in": "body",
